# Gateway destination overrides (optional).
# Production defaults live in src/config/portfolios.ts:
#   gateway → https://donaldjordy.com
#   ai      → https://ai.donaldjordy.com
#   data    → https://data.donaldjordy.com
#
# For LOCAL development, copy this file to `.env.local` and point the panels at
# your local dev servers:
VITE_GATEWAY_URL=http://localhost:5175
VITE_AI_PORTFOLIO_URL=http://localhost:5173
VITE_DATA_PORTFOLIO_URL=http://localhost:3000
